rules_version = '2';

// ============================================================================
// FIRESTORE SECURITY RULES — MAESTRO ÚNICO (LANDING + CRM)
// ============================================================================
// Proyecto Firebase  : cpii-landing (Landing + CRM consumen este proyecto)
// tenant_id canónico : cpii_v1.0 (legacy, activo) + cpii_v1.1 (staging/prod v1.1)
// Doctrina           : ATOM-07 (default-deny) | ATOM-02 (tenant isolation)
//                      ATOM-06 (_slug_reservations) | ATOM-08 (events append-only)
//                      ATOM-05 (soft-delete only en contacts + compliance_alerts)
// Fuente             : Merge forense de dos archivos — REBORN-02.2 Fusión:
//                        A) CPII_v1.1/firestore.rules (Landing — captación anónima)
//                        B) CPII_crm_v1.1/firestore.rules (CRM v2.0.0 — REBORN-02.2)
// Principio          : Aislamiento Lógico Perimetral — JWT como muro criptográfico
//                      Coexistencia Controlada v1.0/v1.1 — Opción A (REBORN-02.2)
// Timestamp          : 2026-05-19
// Versión            : 3.1.0 — REBORN-02.2 BACKWARD COMPAT
// ============================================================================
// CHANGELOG v3.1.0 (OPCIÓN A — COEXISTENCIA CONTROLADA):
//   CONTEXT: v1.0 activo en producción (cpii.digital) + v1.1 en staging (Vercel).
//            Ambos conectan al mismo proyecto Firebase 'cpii-landing'.
//            Deploy desde CPII_v1.1/ sobreescribe reglas para TODOS los clientes.
//   UPD: belongsToTenant() — allowlist ['cpii_v1.0','cpii_v1.1'] + match dinámico
//        con tenant_id del documento. Doble muro: tenant conocido Y aislamiento
//        cruzado (v1.0 staff no puede leer docs v1.1 y viceversa).
//   UPD: isCreateValid() — acepta ambos tenants en el allowlist.
//        Sigue exigiendo token.tenant_id == resource.data.tenant_id (marca nacimiento).
//   UPD: isTenantCpii() — acepta ambos tenants para escrituras anónimas.
//        El formulario v1.0 escribe tenant_id='cpii_v1.0' — ya no bloqueado.
//   UPD: isStaff() — añadido rol legacy 'staff' (v1.0) al array canónico.
//        Roles completos: ['staff','admin','compliance','manager','agent'].
//   KEEP: isAdmin(), isCompliance() — hardcodeados a cpii_v1.1 (roles CRM inexistentes en v1.0)
// ─────────────────────────────────────────────────────────────────────────────
// CHANGELOG v3.0.0 (MERGE FORENSE):
//   FIX: belongsToTenant() — hardcoded 'cpii_v1.1', no dinámico (ATOM-02 estricto)
//   FIX: isStaff() — roles canónicos: [admin, compliance, manager, agent]
//   FIX: _slug_reservations — if false (Admin SDK only, ATOM-06)
//   FIX: contacts/events — update+delete explícitamente if false (ATOM-08)
//   FIX: staff — write restringido a isAdmin() solamente
//   ADD: isAdmin(), isCompliance(), isDocumentOwner() (aportados por CRM v2.0.0)
//   ADD: users, compliance_alerts, audit_log, public_content (aportados por CRM)
//   KEEP: leads anonymous create, contacts GA-02, kpi_daily (aportados por Landing)
// ============================================================================
// DESPLIEGUE (DIR-01):
//   cd C:\BreederHub\01_PRODUCTION\CPII_v1.1
//   firebase deploy --only firestore:rules
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNCIONES DE BLINDAJE ──────────────────────────────────────────────

    // Verifica que el token JWT del usuario pertenece a un tenant canónico autorizado
    // Y que coincide con el tenant_id del documento al que intenta acceder.
    //
    // Doble muro de seguridad (Opción A — coexistencia v1.0/v1.1):
    //   1. Allowlist: token.tenant_id debe ser uno de los tenants conocidos
    //      (anti-spoofing — un tenant arbitrario 'cpii_hack' no pasa)
    //   2. Match dinámico: token.tenant_id == doc.tenant_id
    //      (aislamiento cruzado — staff v1.0 no puede leer docs v1.1 y viceversa)
    //
    // resource.exists ternario: maneja tanto lecturas (resource.data) como
    // operaciones sobre docs inexistentes (request.resource.data en create).
    function belongsToTenant() {
      return request.auth != null &&
             request.auth.token.tenant_id in ['cpii_v1.0', 'cpii_v1.1'] &&
             request.auth.token.tenant_id == (resource.exists ? resource.data.tenant_id
                                                               : request.resource.data.tenant_id);
    }

    // Verifica que el documento a crear lleva el tenant_id correcto.
    // "Marca de Nacimiento" — obligatorio en todo addDoc/setDoc AUTENTICADO.
    // Regla: token.tenant_id debe estar en el allowlist Y coincidir con el campo del doc.
    // Garantiza que un usuario v1.0 no puede crear un doc con tenant_id='cpii_v1.1'.
    // No usar en rutas anónimas (request.auth == null) — usar isTenantCpii().
    function isCreateValid() {
      return request.auth != null &&
             request.auth.token.tenant_id in ['cpii_v1.0', 'cpii_v1.1'] &&
             request.resource.data.tenant_id == request.auth.token.tenant_id;
    }

    // Verificación ligera de tenant para escrituras ANÓNIMAS (request.auth == null).
    // Usado en flujos de captación pública: leads desde access-form, contacts GA-02.
    // Solo verifica el campo del documento — no puede verificar el JWT (no hay auth).
    // Acepta ambos tenants: v1.0 (formulario activo en producción) y v1.1 (staging).
    function isTenantCpii() {
      return request.resource.data.tenant_id in ['cpii_v1.0', 'cpii_v1.1'];
    }

    // Rol Staff — acceso operativo dentro del tenant del usuario.
    // Roles canónicos v1.1: admin, compliance, manager, agent.
    // Rol legacy v1.0:      staff (rol único del sistema anterior).
    // Array completo: ['staff','admin','compliance','manager','agent'].
    // isAdmin() e isCompliance() siguen hardcodeados a cpii_v1.1 —
    // esos roles no existen en v1.0 y no deben heredarse.
    function isStaff() {
      return request.auth != null &&
             request.auth.token.tenant_id in ['cpii_v1.0', 'cpii_v1.1'] &&
             request.auth.token.role in ['staff', 'admin', 'compliance', 'manager', 'agent'];
    }

    // Rol Admin exclusivo — operaciones destructivas y configuración.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1' &&
             request.auth.token.role == 'admin';
    }

    // Rol Compliance — acceso a alertas KYC/AML y datos sensibles.
    // Jerarquía acumulativa: admin hereda permisos de compliance.
    function isCompliance() {
      return request.auth != null &&
             request.auth.token.tenant_id == 'cpii_v1.1' &&
             request.auth.token.role in ['admin', 'compliance'];
    }

    // El usuario autenticado es el agente asignado al documento (ownerId).
    // Permite que el agente lea/modifique sus propios leads sin ser isStaff completo.
    function isDocumentOwner() {
      return request.auth != null &&
             resource.data.ownerId == request.auth.uid;
    }


    // ── COLECCIÓN: leads ──────────────────────────────────────────────────
    // Captación anónima desde access-form.html (CPII_v1.1 Landing).
    // Origen: Landing rules v1.x — preservado íntegramente.
    //
    // Ruta anónima: cualquier visitante puede enviar un lead (request.auth == null).
    // Campos obligatorios: email + full_name + rgpd_consent + tenant_id.
    // El RGPD consent es OBLIGATORIO — ningún lead sin consentimiento explícito.
    //
    // Staff: puede leer, actualizar y eliminar leads desde el CRM.
    // (Eliminación física permitida en leads — no son fichas canónicas CONTACT_SCHEMA)
    match /leads/{leadId} {
      allow create: if request.auth == null
                    && request.resource.data.keys().hasAll(['email', 'full_name', 'rgpd_consent', 'tenant_id'])
                    && isTenantCpii()
                    && request.resource.data.email is string
                    && request.resource.data.full_name is string
                    && request.resource.data.rgpd_consent == true;

      allow read, update, delete: if belongsToTenant() && isStaff();
    }


    // ── COLECCIÓN: contacts ───────────────────────────────────────────────
    // Ficha canónica del inversor (CONTACT_SCHEMA). Dos rutas de entrada:
    //
    // Ruta 1 — Anónima (GA-02 bridge): access-form escribe directamente a contacts.
    //   Activar cuando at-attribution.js → contacts-service.js esté conectado (GA-02).
    //   Campos mínimos: email + tenant_id + createdBy == 'access-form'.
    //   ⚠️ Seguridad: cualquier cliente que conozca el projectId puede usar esta ruta.
    //   Mitigación futura: Firebase App Check.
    //
    // Ruta 2 — Staff autenticado: acceso CRM completo.
    //
    // Borrado físico PROHIBIDO — solo soft-delete (isActive=false) — ATOM-05.
    match /contacts/{contactId} {
      allow create: if (
                      // Ruta 1: captación anónima GA-02 (access-form → contacts)
                      (request.auth == null
                        && request.resource.data.keys().hasAll(['email', 'tenant_id', 'createdBy'])
                        && isTenantCpii()
                        && request.resource.data.email is string
                        && request.resource.data.createdBy == 'access-form')
                      ||
                      // Ruta 2: staff autenticado desde CRM
                      (isCreateValid() && isStaff())
                    );

      allow read:   if belongsToTenant() && (isStaff() || isDocumentOwner());
      allow update: if belongsToTenant() && isStaff();
      allow delete: if false; // Soft-delete ÚNICAMENTE (isActive=false) — ATOM-05

      // ── SUBCOLECCIÓN: events (append-only — ATOM-08) ──────────────────
      // Historial inmutable de transiciones de pipeline y touchpoints.
      // Solo staff puede crear. NADIE puede editar ni borrar.
      // CORRECCIÓN v3.0.0: Landing dejaba update+delete implícitamente abiertos.
      match /events/{eventId} {
        allow read:           if belongsToTenant() && isStaff();
        allow create:         if isCreateValid()   && isStaff();
        allow update, delete: if false; // Inmutable — append-only ATOM-08
      }
    }


    // ── COLECCIÓN: users ──────────────────────────────────────────────────
    // Perfiles de usuario (agentes, compliance, admins) + Custom Claims mirror.
    // Cada usuario lee/actualiza su propio perfil. Admin puede leer cualquier perfil.
    // Origen: CRM v2.0.0.
    match /users/{uid} {
      allow read:   if belongsToTenant() && (request.auth.uid == uid || isAdmin());
      allow update: if belongsToTenant() &&  request.auth.uid == uid;
      allow create: if isCreateValid();
      allow delete: if false;
    }


    // ── COLECCIÓN: _slug_reservations ─────────────────────────────────────
    // Centinela de unicidad de slugs de embajadores (ATOM-06).
    // Opera EXCLUSIVAMENTE vía Firebase Admin SDK (Cloud Functions).
    // Admin SDK bypasses rules — las reglas bloquean acceso desde cliente.
    // CORRECCIÓN v3.0.0: Landing permitía staff read/write — incorrecto,
    // permitía manipulación directa de slugs desde el cliente.
    match /_slug_reservations/{slug} {
      allow read, write: if false; // Admin SDK only — bypasses rules
    }


    // ── COLECCIÓN: staff ──────────────────────────────────────────────────
    // Lista de agentes/gestores/compliance (metadatos + licencia AMI).
    // Staff puede leer sus propios registros y los del equipo.
    // Solo Admin puede crear o modificar registros de staff.
    // CORRECCIÓN v3.0.0: Landing permitía cualquier staff escribir.
    match /staff/{staffId} {
      allow read:  if belongsToTenant() && isStaff();
      allow write: if belongsToTenant() && isAdmin();
    }


    // ── COLECCIÓN: compliance_alerts ──────────────────────────────────────
    // Alertas KYC/AML/PEP activas e históricas.
    // Solo Compliance (admin + compliance role) puede leer y operar.
    // Las alertas son inmutables — solo se marcan como resolved (update, no delete).
    // Origen: CRM v2.0.0.
    match /compliance_alerts/{alertId} {
      allow read:   if belongsToTenant() && isCompliance();
      allow create: if isCreateValid()   && isCompliance();
      allow update: if belongsToTenant() && isCompliance();
      allow delete: if false; // Alertas inmutables — solo se marcan resolved
    }


    // ── COLECCIÓN: audit_log ──────────────────────────────────────────────
    // Bitácora append-only de eventos críticos del sistema.
    // Solo Compliance puede leer. Solo sistema (Admin SDK) puede escribir.
    // Origen: CRM v2.0.0.
    match /audit_log/{eventId} {
      allow read:           if belongsToTenant() && isCompliance();
      allow create:         if false; // Admin SDK only — sistema escribe
      allow update, delete: if false; // Append-only absoluto
    }


    // ── COLECCIÓN: kpi_daily ──────────────────────────────────────────────
    // Preagregados de dashboard (métricas diarias).
    // Staff puede leer y escribir desde el CRM.
    // Origen: Landing rules — colección específica de CPII.
    // TODO (Fase B): evaluar si write debe restringirse a Admin SDK únicamente.
    match /kpi_daily/{dateId} {
      allow read:  if belongsToTenant() && isStaff();
      allow write: if belongsToTenant() && isStaff();
    }


    // ── COLECCIÓN: public_content ─────────────────────────────────────────
    // Contenido global sin restricción de tenant (textos públicos, FAQs, etc.).
    // Origen: CRM v2.0.0.
    match /public_content/{contentId} {
      allow read: if true;
    }


    // ── DEFAULT-DENY ──────────────────────────────────────────────────────
    // Cierre total: cualquier ruta no declarada explícitamente → denegada.
    // Doctrina ATOM-07: Zero Trust — lo no permitido es denegado.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
