{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "src/**",
      "package*.json",
      "tailwind.config.js",
      "postcss.config.js",
      "*.md",
      ".env*"
    ],
    "redirects": [
      {
        "source": "**/access_form.html",
        "destination": "/access-form.html",
        "type": 301
      }
    ]
  }
}